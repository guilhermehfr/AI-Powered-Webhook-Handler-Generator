## Example .env for API (local development)
# Copy this file to api/.env and replace the placeholders with real values.

# Postgres connection (example for docker-compose in repo)
DATABASE_URL=postgresql://docker:docker@localhost:5432/webhooks

# Groq API key (used by the handler generator)
GROQ_API_KEY=your_groq_api_key_here

# API port (optional, default in code is 3333)
PORT=3333